ACTION402_PROFILE=testnet
PORT=4021
HOST=127.0.0.1
X402_ENABLED=true

# User-owned values:
PAY_TO=0xYourReceivingWallet
RECEIPT_KEY_ID=testnet-v1
RECEIPT_SECRET=replace-with-a-random-secret-at-least-24-chars
RECEIPT_PREVIOUS_SECRETS=
PUBLIC_BASE_URL=http://127.0.0.1:4021

# Base Sepolia / x402 testnet:
X402_NETWORK=eip155:84532
X402_PRICE=$0.003
FACILITATOR_URL=https://x402.org/facilitator

STORE_DRIVER=json
STORE_FILE=data/action402-testnet-store.json
# For managed Postgres testnet:
# STORE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host:5432/action402_testnet
# POSTGRES_SSL=true
JOB_RETENTION_MS=604800000
RECEIPT_RETENTION_MS=2592000000
MAX_WEBHOOK_TIMEOUT_MS=12000
MAX_RETRY_ATTEMPTS=3
ALLOW_HTTP_TARGETS=false

TARGET_ALLOWLIST=
TARGET_BLOCKLIST=
REQUIRE_TARGET_ALLOWLIST=false
TARGET_POLICY_PRESET=open

TARGET_QUOTA_ENABLED=true
TARGET_QUOTA_WINDOW_MS=60000
TARGET_QUOTA_MAX_REQUESTS=20

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

LOG_LEVEL=info
REQUEST_LOG_ENABLED=true
