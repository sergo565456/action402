ACTION402_PROFILE=mainnet
PORT=4021
HOST=0.0.0.0
X402_ENABLED=true

# User-owned values:
PAY_TO=0xYourReceivingWallet
RECEIPT_KEY_ID=mainnet-v1
RECEIPT_SECRET=replace-with-a-random-secret-at-least-24-chars
RECEIPT_PREVIOUS_SECRETS=
PUBLIC_BASE_URL=https://your-action402-domain.example
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Base mainnet / CDP facilitator:
X402_NETWORK=eip155:8453
X402_PRICE=$0.003
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

STORE_DRIVER=postgres
DATABASE_URL=postgres://user:password@host:5432/action402
POSTGRES_SSL=true
# Local JSON fallback only for dry runs:
# STORE_DRIVER=json
STORE_FILE=data/action402-mainnet-store.json
JOB_RETENTION_MS=604800000
RECEIPT_RETENTION_MS=2592000000
MAX_WEBHOOK_TIMEOUT_MS=12000
MAX_RETRY_ATTEMPTS=3
ALLOW_HTTP_TARGETS=false

# Strongly recommended before mainnet traffic:
TARGET_ALLOWLIST=
TARGET_BLOCKLIST=
REQUIRE_TARGET_ALLOWLIST=false

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

LOG_LEVEL=info
REQUEST_LOG_ENABLED=true
