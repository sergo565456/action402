ACTION402_PROFILE=demo
PORT=4021
X402_ENABLED=false

PUBLIC_BASE_URL=http://localhost:4021
RECEIPT_KEY_ID=demo
RECEIPT_SECRET=demo-local-receipt-secret-not-for-production
RECEIPT_PREVIOUS_SECRETS=
STORE_DRIVER=json
STORE_FILE=data/action402-demo-store.json
# Optional managed Postgres:
# DATABASE_URL=
# POSTGRES_SSL=false
JOB_RETENTION_MS=604800000
RECEIPT_RETENTION_MS=2592000000

MAX_WEBHOOK_TIMEOUT_MS=12000
MAX_RETRY_ATTEMPTS=3
ALLOW_HTTP_TARGETS=false

TARGET_ALLOWLIST=
TARGET_BLOCKLIST=
REQUIRE_TARGET_ALLOWLIST=false

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

LOG_LEVEL=info
REQUEST_LOG_ENABLED=true
