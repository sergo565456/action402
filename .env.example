PORT=4021
HOST=127.0.0.1

# Local demo mode:
X402_ENABLED=false

# Production x402 mode:
# X402_ENABLED=true
# PAY_TO=0xYourReceivingWallet
# X402_NETWORK=eip155:8453
# X402_PRICE=$0.003
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Testnet mode:
# X402_NETWORK=eip155:84532
# FACILITATOR_URL=https://x402.org/facilitator

PUBLIC_BASE_URL=http://127.0.0.1:4021
RECEIPT_KEY_ID=default
RECEIPT_SECRET=change-this-before-production
RECEIPT_PREVIOUS_SECRETS=
STORE_DRIVER=json
STORE_FILE=data/action402-store.json
# For managed Postgres, set:
# STORE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host:5432/action402
# POSTGRES_SSL=true
JOB_RETENTION_MS=604800000
RECEIPT_RETENTION_MS=2592000000

MAX_WEBHOOK_TIMEOUT_MS=12000
MAX_RETRY_ATTEMPTS=3
ALLOW_HTTP_TARGETS=false

# Target policy:
# Comma-separated hostnames. Exact domains and wildcard subdomains are supported.
# Example: TARGET_ALLOWLIST=api.example.com,*.trusted.example
TARGET_ALLOWLIST=
TARGET_BLOCKLIST=
REQUIRE_TARGET_ALLOWLIST=false

# Basic per-client limit for paid execution endpoint.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Observability:
LOG_LEVEL=info
REQUEST_LOG_ENABLED=true
